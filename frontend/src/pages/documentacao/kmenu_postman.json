                            "path": ["dashboard"]
                        },
                        "description": "Dados para dashboard analytics"
                    }
                }
            ]
        },
        {
            "name": "Webhooks",
            "item": [
                {
                    "name": "Exemplo Webhook - Ticket Criado",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "X-WhatTicket-Event",
                                "value": "ticket:create"
                            }
                        ],
                        "url": {
                            "raw": "https://sua-url.com/webhook",
                            "protocol": "https",
                            "host": ["sua-url", "com"],
                            "path": ["webhook"]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"event\": \"ticket:create\",\n    \"timestamp\": \"2025-01-15T10:30:00Z\",\n    \"data\": {\n        \"id\": 123,\n        \"status\": \"open\",\n        \"contactId\": 1,\n        \"userId\": 1,\n        \"queueId\": 1,\n        \"createdAt\": \"2025-01-15T10:30:00Z\",\n        \"updatedAt\": \"2025-01-15T10:30:00Z\"\n    }\n}"
                        },
                        "description": "Exemplo de webhook enviado quando um ticket é criado"
                    }
                },
                {
                    "name": "Exemplo Webhook - Mensagem Recebida",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "X-WhatTicket-Event",
                                "value": "message:create"
                            }
                        ],
                        "url": {
                            "raw": "https://sua-url.com/webhook",
                            "protocol": "https",
                            "host": ["sua-url", "com"],
                            "path": ["webhook"]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"event\": \"message:create\",\n    \"timestamp\": \"2025-01-15T10:30:00Z\",\n    \"data\": {\n        \"id\": 456,\n        \"body\": \"Nova mensagem recebida\",\n        \"ticketId\": 123,\n        \"contactId\": 1,\n        \"fromMe\": false,\n        \"mediaType\": \"text\",\n        \"timestamp\": \"2025-01-15T10:30:00Z\",\n        \"ack\": 2\n    }\n}"
                        },
                        "description": "Exemplo de webhook enviado quando uma mensagem é recebida"
                    }
                }
            ]
        }
    ]
