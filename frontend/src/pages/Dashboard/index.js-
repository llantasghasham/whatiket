    color: "white",
    padding: theme.spacing(1, 2),
    borderRadius: "12px",
    border: "none",
    fontWeight: 600,
    display: "flex",
    alignItems: "center",
    gap: theme.spacing(1),
    
    "&:hover": {
      backgroundColor: "#4f46e5",
    },
  },

  attendantGrid: {
    display: "grid",
    gridTemplateColumns: "repeat(auto-fill, minmax(300px, 1fr))",
    gap: theme.spacing(2),
    marginBottom: theme.spacing(4),
  },

  attendantCard: {
    backgroundColor: "#f8fafc",
    borderRadius: "12px",
    padding: theme.spacing(2),
    border: "1px solid #e2e8f0",
    display: "flex",
    alignItems: "center",
    gap: theme.spacing(2),
    transition: "all 0.2s ease",
    
    "&:hover": {
