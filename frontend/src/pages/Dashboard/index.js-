  },

  attendantAvatar: {
    width: "44px",
    height: "44px",
    borderRadius: "12px",
    fontSize: "16px",
    fontWeight: 600,
  },

  onlineAvatar: {
    backgroundColor: "#10b981",
    color: "white",
  },

  offlineAvatar: {
